*.spec.bak
build/
dist/

# ===========================================
# Runtime Data
# ===========================================
*.log
rundata/logs/*.log
rundata/input/*
rundata/output/*

# Keep .gitkeep files
!rundata/input/.gitkeep
!rundata/output/.gitkeep
!rundata/logs/.gitkeep


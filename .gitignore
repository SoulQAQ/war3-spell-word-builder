.playwright-mcp/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
dist/
build/
*.manifest

# ===========================================
# Virtual Environment
# ===========================================
.venv/
venv/
ENV/
env/

# ===========================================
# IDE
# ===========================================
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-*

# ===========================================
